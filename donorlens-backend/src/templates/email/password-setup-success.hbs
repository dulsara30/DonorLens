      }
      .security-tips li {
        margin: 8px 0;
        font-size: 14px;
      }
      .footer {
        background: #f9fafb;
        padding: 30px;
        text-align: center;
        border-top: 1px solid #e5e7eb;
      }
      .footer p {
        margin: 5px 0;
        font-size: 14px;
        color: #6b7280;
      }
      hr {
        border: none;
        border-top: 1px solid #e5e7eb;
        margin: 30px 0;
      }
    </style>
  </head>
  <body>

    <div class="container">

      <!-- Header -->
      <div class="header">
        <div class="emoji">✅</div>
        <h1>You're All Set!</h1>
      </div>

      <!-- Content -->
      <div class="content">

        <!-- Success Badge -->
        <div class="success-badge">
          <div class="checkmark">✓</div>
          <h2>Password Set Successfully!</h2>
        </div>

        <p style="font-size: 16px; color: #4b5563; text-align: center;">
          Dear
          <strong style="color: #10b981;">{{ngoName}}</strong>, your account is
          now fully activated and ready to use!
        </p>

        <!-- Credentials Box -->
        <div class="credentials-box">
          <h3>🔑 Your Login Credentials</h3>

          <div class="credential-item">
            <strong>Email Address</strong>
            <span>{{email}}</span>
          </div>

          <div class="credential-item">
            <strong>Password</strong>
            <span>The one you just created</span>
          </div>

          <a href="{{loginUrl}}" class="cta-button">
            🚀 Login to Dashboard
          </a>
        </div>

        <!-- Next Steps -->
        <div class="next-steps">
          <h3>🌟 What's Next?</h3>
          <ol>
            <li><strong>Complete Your Profile</strong>
              – Add your NGO logo, description, and contact details</li>
            <li><strong>Create Your First Campaign</strong>
              – Start fundraising for your cause</li>
            <li><strong>Add Financial Breakdown</strong>
              – Show donors exactly how funds will be used</li>
            <li><strong>Share with Donors</strong>
              – Promote your campaigns to receive donations</li>
            <li><strong>Track Your Impact</strong>
              – Update supporters on your progress</li>
          </ol>
        </div>

        <!-- Security Tips -->
        <div class="security-tips">
          <strong>🔒 Security Reminders:</strong>
          <ul>
            <li>Never share your password with anyone</li>
            <li>Use a unique password only for DonorLens</li>
            <li>Log out when using shared computers</li>
            <li>Change your password regularly (every 3-6 months)</li>
            <li>Enable email notifications for account activity</li>
          </ul>
        </div>

        <hr />

        <p style="text-align: center; font-size: 15px; color: #6b7280;">
          Need help getting started? Check out our
          <a
            href="{{dashboardUrl}}/help"
            style="color: #10b981; text-decoration: none; font-weight: 600;"
          >Help Center</a>
          or contact support at
          <a
            href="mailto:support@donorlens.com"
            style="color: #10b981; text-decoration: none; font-weight: 600;"
          >support@donorlens.com</a>
        </p>

      </div>

      <!-- Footer -->
      <div class="footer">
        <p style="font-weight: 700; color: #111827;">Welcome to the DonorLens
          family! 💚</p>
        <p>The DonorLens Team</p>
        <p style="font-size: 12px; color: #9ca3af; margin-top: 20px;">
          ©
          {{currentYear}}
          DonorLens. All rights reserved.
        </p>
      </div>

    </div>

  </body>
</html>