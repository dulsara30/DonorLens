{{! filepath: d:\Projects\DonorLens\donorlens-backend\src\templates\email\ngo-password-setup.hbs }}


<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Set Up Your DonorLens Account</title>
    <style>
      body {
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        line-height: 1.6;
        color: #333;
        margin: 0;
        padding: 0;
        background-color: #f5f5f5;
      }
      .container {
        max-width: 600px;
        margin: 20px auto;
        background: #ffffff;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
      }
      .header {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        padding: 40px 30px;
        text-align: center;
      }
      .header h1 {
        color: white;
        margin: 0;
        font-size: 28px;
        font-weight: 700;
      }
      .header .emoji {
        font-size: 48px;
        margin-bottom: 10px;
      }
      .content {
        padding: 40px 30px;
      }
      .greeting {
        font-size: 18px;
        margin-bottom: 20px;
        color: #111827;
      }
      .greeting strong {
        color: #10b981;
        font-weight: 700;
      }
      .message {
        font-size: 16px;
        color: #4b5563;
        margin-bottom: 30px;
        line-height: 1.8;
      }
      .cta-box {
        background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
        border-left: 4px solid #10b981;
        padding: 30px;
        margin: 30px 0;
        border-radius: 8px;
        text-align: center;
      }
      .cta-box h3 {
        margin: 0 0 15px 0;
        color: #10b981;
        font-size: 20px;
        font-weight: 700;
      }
      .cta-box p {
        margin: 0 0 20px 0;
        color: #4b5563;
        font-size: 15px;
      }
      .cta-button {
        display: inline-block;
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        color: white !important;
        padding: 16px 40px;
        text-decoration: none;
        border-radius: 8px;
        font-weight: 700;
        font-size: 16px;
        margin: 10px 0;
        transition: transform 0.2s;
        box-shadow: 0 4px 6px rgba(16, 185, 129, 0.3);
      }
      .cta-button:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 8px rgba(16, 185, 129, 0.4);
      }
      .link-text {
        margin-top: 20px;
        font-size: 13px;
        color: #6b7280;
      }
      .link-text a {
        color: #10b981;
        word-break: break-all;
        text-decoration: none;
      }
      .warning-box {
        background: #fef3c7;
        border-left: 4px solid #f59e0b;
        padding: 20px;
        margin: 30px 0;
        border-radius: 8px;
      }
      .warning-box p {
        margin: 0 0 10px 0;
        font-size: 14px;
        color: #78350f;
      }
      .warning-box strong {
        color: #92400e;
        font-weight: 700;
      }
      .warning-box ul {
        margin: 10px 0 0 0;
        padding-left: 20px;
        color: #78350f;
      }
      .warning-box li {
        margin: 8px 0;
        font-size: 14px;
      }
      .info-box {
        background: #ffffff;
        border: 2px solid #e5e7eb;
        padding: 25px;
        margin: 30px 0;
        border-radius: 8px;
      }
      .info-box h3 {
        margin: 0 0 15px 0;
        color: #374151;
        font-size: 18px;
        font-weight: 700;
      }
      .info-item {
        background: #f9fafb;
        padding: 12px 15px;
        margin: 10px 0;
        border-radius: 6px;
        border-left: 3px solid #10b981;
      }
      .info-item strong {
        color: #111827;
        font-weight: 600;
        display: inline-block;
        min-width: 180px;
      }
      .info-item span {
        color: #4b5563;
      }
      .support-box {
        background: #f3f4f6;
        padding: 20px;
        margin: 30px 0;
        border-radius: 8px;
        text-align: center;
      }
      .support-box p {
        margin: 0;
        font-size: 14px;
        color: #6b7280;
      }
      .support-box a {
        color: #10b981;
        text-decoration: none;
        font-weight: 600;
      }
      .footer {
        background: #f9fafb;
        padding: 30px;
        text-align: center;
        border-top: 1px solid #e5e7eb;
      }
      .footer p {
        margin: 5px 0;
        font-size: 14px;
        color: #6b7280;
      }
      .footer strong {
        color: #111827;
        font-weight: 700;
      }
      .footer a {
        color: #10b981;
        text-decoration: none;
        font-weight: 600;
      }
      .copyright {
        font-size: 12px;
        color: #9ca3af;
        margin-top: 20px;
      }
      hr {
        border: none;
        border-top: 1px solid #e5e7eb;
        margin: 30px 0;
      }
    </style>
  </head>
  <body>

    <div class="container">

      <!-- Header -->
      <div class="header">
        <div class="emoji">🎉</div>
        <h1>Welcome to DonorLens!</h1>
      </div>

      <!-- Content -->
      <div class="content">

        <!-- Greeting -->
        <p class="greeting">
          Dear
          <strong>{{ngoName}}</strong>,
        </p>

        <!-- Main Message -->
        <p class="message">
          Congratulations! Your NGO registration has been
          <strong style="color: #10b981;">approved</strong>
          by our admin team. We're excited to have you join our platform to make
          a real impact in your community! 🌟
        </p>

        <!-- CTA Box -->
        <div class="cta-box">
          <h3>📝 Set Up Your Password</h3>
          <p>
            To complete your account setup and start creating campaigns, please
            set up your password by clicking the button below:
          </p>

          <a href="{{setupUrl}}" class="cta-button">
            Set Up My Password
          </a>

          <div class="link-text">
            Or copy and paste this link into your browser:<br />
            <a href="{{setupUrl}}">{{setupUrl}}</a>
          </div>
        </div>

        <!-- Warning Box -->
        <div class="warning-box">
          <p><strong>⚠️ Important Security Information:</strong></p>
          <ul>
            <li><strong>This link expires in {{expiryHours}} hours</strong>
              – Please complete setup soon</li>
            <li>The link can only be used
              <strong>once</strong>
              for security</li>
            <li>You'll need your
              <strong>email</strong>
              and
              <strong>registration number</strong>
              to verify your identity</li>
            <li>Choose a strong password (minimum 8 characters)</li>
            <li>Never share this link with anyone</li>
          </ul>
        </div>

        <!-- Info Box -->
        <div class="info-box">
          <h3>📋 What You'll Need:</h3>

          <div class="info-item">
            <strong>Email Address:</strong>
            <span>{{email}}</span>
          </div>

          <div class="info-item">
            <strong>Registration Number:</strong>
            <span>{{registrationNumber}}</span>
          </div>

          <div class="info-item">
            <strong>New Password:</strong>
            <span>You'll create this during setup</span>
          </div>
        </div>

        <!-- Next Steps -->
        <div
          class="info-box"
          style="background: #e0f2fe; border-color: #0284c7;"
        >
          <h3 style="color: #0284c7;">🚀 What's Next After Setup?</h3>
          <ol
            style="margin: 10px 0; padding-left: 20px; line-height: 2; color: #075985;"
          >
            <li><strong>Login</strong>
              to your dashboard with your credentials</li>
            <li><strong>Complete</strong> your NGO profile information</li>
            <li><strong>Create</strong>
              your first campaign to start fundraising</li>
            <li><strong>Share</strong> your campaigns with donors worldwide</li>
            <li><strong>Track</strong> donations and manage your impact</li>
          </ol>
        </div>

        <hr />

        <!-- Support -->
        <div class="support-box">
          <p>
            If you didn't request this approval or have any questions, please
            contact our support team immediately at
            <a href="mailto:support@donorlens.com">support@donorlens.com</a>
          </p>
        </div>

      </div>

      <!-- Footer -->
      <div class="footer">
        <p>
          <strong>Best regards,</strong><br />
          The DonorLens Team
        </p>
        <p>
          <a href="https://donorlens.com">donorlens.com</a>
        </p>
        <p class="copyright">
          ©
          {{currentYear}}
          DonorLens. All rights reserved.
        </p>
      </div>

    </div>

  </body>
</html>